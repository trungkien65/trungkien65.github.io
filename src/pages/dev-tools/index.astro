---
import ToolPanel from "@/components/devTools/ToolPanel.astro"
import { Button, Heading, Tabs, Text } from "@/components/ui"
/**
 * Tools — tab dọc; mỗi panel bọc Card (ToolPanel) + island.
 */
import { PublicLayout } from "@/layouts"
import { ALL_TOOLS } from "@/lib/devTools/config"
import { cn } from "@/lib/utils"
---
<PublicLayout title="Dev Tools">
  <div class="space-y-6">
    <div>
      <Heading as="h1" size="xl" class="mb-2">Tools</Heading>
      <Text variant="lead" class="text-muted-foreground">
        Tab dọc; JSON formatter &amp; chuyển đổi XML / CSV / YAML.
      </Text>
    </div>

    <Tabs orientation="vertical" class="w-full min-w-0">
      <div slot="list" class="flex flex-col gap-1">
        {ALL_TOOLS.map((tool, index) => (
          <div class="contents" key={tool.id}>
            <Button
              variant="ghost"
              type="button"
              class={cn(
                "h-auto w-full justify-start whitespace-normal px-3 py-2 text-left text-sm font-normal"
              )}
              role="tab"
              aria-controls={`panel-${tool.id}`}
              aria-selected={index === 0 ? "true" : "false"}
              data-tab-id={tool.id}
            >
              {tool.label}
            </Button>
          </div>
        ))}
      </div>
      <div slot="panels">
        {ALL_TOOLS.map((tool, index) => (
          <div
            role="tabpanel"
            id={`panel-${tool.id}`}
            aria-labelledby={`tab-${tool.id}`}
            aria-hidden={index === 0 ? "false" : "true"}
            hidden={index !== 0}
          >
            <ToolPanel toolId={tool.id} />
          </div>
        ))}
      </div>
    </Tabs>
  </div>
</PublicLayout>

<script>
  import { bootDevTools } from "@/scripts/dev-tools/boot"
  bootDevTools()
</script>
