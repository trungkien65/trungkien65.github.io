---
import ToolPanel from "@/components/devTools/ToolPanel.astro"
import { Heading, Text } from "@/components/ui"
/**
 * Trang từng tool — dùng chung ToolRenderer với /dev-tools
 */
import { DashboardLayout } from "@/layouts"
import { DEV_TOOL_GROUPS } from "@/lib/devTools/config"

export function getStaticPaths() {
  const allTools = DEV_TOOL_GROUPS.flatMap((g) =>
    g.tools.map((tool) => ({
      params: { tool: tool.id },
      props: { tool, group: g }
    }))
  )
  return allTools
}

interface Props {
  tool: { id: string; label: string; href: string; description?: string }
  group: { label: string; description: string }
}

const { tool, group } = Astro.props
---
<DashboardLayout title={`${tool.label} | Dev Tools`}>
  <div class="space-y-6">
    <div>
      <span class="text-sm font-medium text-muted-foreground">{group.label}</span>
      <Heading as="h1" size="xl" class="mb-2 mt-1">{tool.label}</Heading>
      {tool.description && (
        <Text class="text-muted-foreground">{tool.description}</Text>
      )}
    </div>
    <ToolPanel toolId={tool.id} />
  </div>
</DashboardLayout>

<script>
  import { bootDevTools } from "@/scripts/dev-tools/boot"
  bootDevTools()
</script>
