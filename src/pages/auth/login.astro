---
/**
 * Đăng nhập — POST /auth/login, lưu token cookie, chuyển /auth/me.
 */
import { PublicLayout } from "@/layouts"
import { Button, Card, Heading, Input, Link, Text } from "@/components/ui"
---

<PublicLayout title="Đăng nhập">
  <div class="mx-auto max-w-md space-y-6">
    <Heading as="h1" size="xl">Đăng nhập</Heading>
    <Card variant="bordered">
      <form id="auth-login-form" class="space-y-4">
        <Input label="Email" type="email" name="email" id="auth-login-email" required autocomplete="email" />
        <Input
          label="Mật khẩu"
          type="password"
          name="password"
          id="auth-login-password"
          required
          autocomplete="current-password"
        />
        <Button type="submit" variant="primary" class="w-full" id="auth-login-submit">
          Đăng nhập
        </Button>
      </form>
      <Text variant="small" class="mt-4 block">
        Chưa có tài khoản? <Link href="/auth/register">Đăng ký</Link>
        <span class="text-muted-foreground"> · </span>
        <Link href="/dev-tools">Dev Tools</Link> (không cần đăng nhập)
      </Text>
    </Card>
  </div>
</PublicLayout>

<script>
  import { getSafeNextPath } from "@/lib/auth/safeNext"
  import { apiErrorMessage } from "@/lib/api/errors"
  import { authLogin, persistAuthTokenPair } from "@/lib/api/auth"
  import { showToast } from "@/lib/ui/toast"

  const form = document.getElementById("auth-login-form") as HTMLFormElement | null
  const submitBtn = document.getElementById("auth-login-submit") as HTMLButtonElement | null

  form?.addEventListener("submit", async (e) => {
    e.preventDefault()
    if (!submitBtn) return
    submitBtn.disabled = true
    const fd = new FormData(form)
    const email = String(fd.get("email") ?? "").trim()
    const password = String(fd.get("password") ?? "")
    try {
      const tokens = await authLogin({ email, password })
      persistAuthTokenPair(tokens)
      window.location.href = getSafeNextPath(window.location.search)
    } catch (err) {
      showToast(apiErrorMessage(err, "Đăng nhập thất bại"), { variant: "destructive" })
    } finally {
      submitBtn.disabled = false
    }
  })
</script>
