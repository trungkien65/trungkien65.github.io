---
/**
 * Reusable sidebar: menu items with active state by pathname.
 * Desktop: fixed on left. Mobile: collapsible (toggle from Header).
 */
import { Link, List } from "@/components/ui"
import { cn } from "@/lib/utils"

const currentPath = Astro.url.pathname

const menuItems = [
  { href: "/", label: "Dashboard" },
  { href: "/theme", label: "Theme" },
  { href: "/learn/vocab", label: "Từ vựng" },
  { href: "/learn/radicals", label: "Bộ thủ" },
  { href: "/game", label: "Game" },
  { href: "/account", label: "Tài khoản" },
]
---
<aside
  id="sidebar"
  class="fixed inset-y-0 left-0 z-40 w-64 shrink-0 border-r border-border bg-card transition-transform duration-200 ease-out lg:translate-x-0"
  aria-label="Sidebar"
>
  <div class="flex h-full flex-col">
    <div class="flex h-14 items-center gap-2 border-b border-border px-4">
      <span class="text-lg font-semibold tracking-tight text-foreground">Dashboard</span>
    </div>
    <nav class="flex-1 overflow-y-auto p-3">
      <List as="ul" class="space-y-0.5">
        {menuItems.map((item) => {
          const isActive =
            item.href === "/" ? currentPath === "/" : currentPath === item.href || currentPath.startsWith(item.href + "/")
          return (
            <li class="!list-none">
              <Link
                href={item.href}
                class={cn(
                  "flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium transition-colors hover:bg-muted hover:text-foreground",
                  isActive && "bg-muted text-foreground"
                )}
              >
                {item.label}
              </Link>
            </li>
          )
        })}
      </List>
    </nav>
    <div class="border-t border-border px-4 py-2 text-xs text-muted-foreground">
      v1.0.0
    </div>
  </div>
</aside>
