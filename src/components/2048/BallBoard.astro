---
/**
 * Ball game — vanilla JS + Astro.
 */
import { Button } from "@/components/ui"
import "@/styles/ballgame.css"
---
<div class="flex flex-col gap-4" data-ball-game-root>
  <div class="flex items-center justify-between text-foreground">
    <span class="font-semibold">Score: <span data-ball-score>0</span></span>
    <Button type="button" variant="outline" size="sm" data-ball-reset>
      Reset
    </Button>
  </div>
  <div class="flex justify-center">
    <div
      class="ball-game-board cursor-crosshair select-none touch-none"
      role="application"
      aria-label="Move mouse to choose position, click to drop ball"
    >
      <div class="ball-game-preview-line" aria-hidden="true"></div>
      <div data-ball-layer class="absolute inset-0"></div>
    </div>
  </div>
</div>

<script>
  import { initBallGame } from "@/scripts/ball-game"
  document.querySelectorAll("[data-ball-game-root]").forEach((root) => initBallGame(root as HTMLElement))
</script>
