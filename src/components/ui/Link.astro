---
/**
 * Link: primary, secondary, muted. Reusable styled link.
 */
import { cn } from "@/lib/utils"

interface Props {
  href: string
  variant?: "primary" | "secondary" | "muted"
  class?: string
  external?: boolean
}

const { href, variant = "primary", class: className = "", external = false } = Astro.props

const base = "font-medium transition-colors focus:outline-none focus:underline rounded focus:ring-2 focus:ring-offset-2 focus:ring-primary"
const variants = {
  primary: "text-primary hover:opacity-80",
  secondary: "text-muted-foreground hover:text-foreground",
  muted: "text-muted-foreground hover:text-foreground",
}
---
<a
  href={href}
  class={cn(base, variants[variant], className)}
  target={external ? "_blank" : undefined}
  rel={external ? "noopener noreferrer" : undefined}
>
  <slot />
</a>
