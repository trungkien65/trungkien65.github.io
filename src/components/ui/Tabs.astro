---
/**
 * Tabs: tab list slot + panels. Use role="tablist" and aria. Client script to switch tabs.
 * orientation: horizontal (default) | vertical - tab list theo chiều ngang hoặc dọc
 */
import { cn } from "@/lib/utils"

interface Props {
  class?: string
  orientation?: "horizontal" | "vertical"
}

const { class: className = "", orientation = "horizontal" } = Astro.props
const isVertical = orientation === "vertical"
const tabListClass = cn(
  "rounded-lg p-1",
  isVertical
    ? "flex max-h-[70vh] w-full min-w-0 shrink-0 flex-col overflow-y-auto sm:min-w-[11rem] sm:max-w-[14rem]"
    : "flex gap-1"
)
---
<div class={cn("tabs-root", isVertical && "flex gap-4", className)} data-tabs>
  <div role="tablist" class={tabListClass} aria-label={isVertical ? "Danh sách tab" : "Tabs"}>
    <slot name="list" />
  </div>
  <div class={cn(isVertical ? "min-w-0 flex-1" : "mt-3")}>
    <slot name="panels" />
  </div>
</div>

<style>
  .tabs-root [role="tab"] {
    @apply rounded-md px-3 py-2 text-sm font-medium text-muted-foreground transition-colors hover:text-foreground;
  }
  .tabs-root [role="tab"][aria-selected="true"] {
    @apply bg-muted text-foreground shadow-sm ring-1 ring-border;
  }
  /* Panel: dùng thuộc tính HTML hidden (UA ẩn trước CSS bundle) — tránh nháy khi reload */
  .tabs-root [role="tabpanel"][hidden] {
    display: none !important;
  }
</style>

<script>
  document.querySelectorAll("[data-tabs]").forEach((root) => {
    const tabs = root.querySelectorAll('[role="tab"]')
    const panels = root.querySelectorAll('[role="tabpanel"]')
    const select = (i: number) => {
      tabs.forEach((t, j) => {
        ;(t as HTMLElement).setAttribute("aria-selected", j === i ? "true" : "false")
      })
      panels.forEach((p, j) => {
        const on = j === i
        const el = p as HTMLElement
        el.setAttribute("aria-hidden", on ? "false" : "true")
        el.hidden = !on
      })
    }
    tabs.forEach((tab, i) => {
      tab.addEventListener("click", () => select(i))
    })
    const initial = [...tabs].findIndex((t) => t.getAttribute("aria-selected") === "true")
    select(initial >= 0 ? initial : 0)
  })
</script>
