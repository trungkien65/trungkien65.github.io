---
/**
 * Text: paragraph / span with variant (lead, default, muted, small).
 */
import { cn } from "@/lib/utils"

interface Props {
  as?: "p" | "span" | "div"
  variant?: "lead" | "default" | "muted" | "small"
  class?: string
  [key: string]: unknown
}

const {
  as = "p",
  variant = "default",
  class: className = "",
  key: _key,
  slot: _slot,
  ...rest
} = Astro.props as Props & { key?: unknown; slot?: unknown }

type Variant = NonNullable<Props["variant"]>
const base = "leading-relaxed"
const variants: Record<Variant, string> = {
  lead: "text-lg text-foreground",
  default: "text-base text-foreground",
  muted: "text-base text-muted-foreground",
  small: "text-sm text-muted-foreground",
}

const Tag = as
---
<Tag class={cn(base, variants[variant as Variant], className)} {...rest}>
  <slot />
</Tag>
