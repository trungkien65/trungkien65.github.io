---
/**
 * Code: inline or block (pre).
 */
import { cn } from "@/lib/utils"

interface Props {
  block?: boolean
  class?: string
}

const { block = false, class: className = "" } = Astro.props

const inlineClass =
  "rounded bg-muted px-1.5 py-0.5 font-mono text-sm text-foreground"
const blockClass =
  "block w-full overflow-x-auto rounded-lg border border-border bg-muted p-4 font-mono text-sm text-foreground"
---
{block ? (
  <pre class={cn(blockClass, className)}>
    <code>
      <slot />
    </code>
  </pre>
) : (
  <code class={cn(inlineClass, className)}>
    <slot />
  </code>
)}
